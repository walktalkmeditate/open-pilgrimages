{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cdn.jsdelivr.net/gh/walktalkmeditate/open-pilgrimages@v1/schema/index.schema.json",
  "title": "Open Pilgrimages Route Index",
  "description": "Registry of all pilgrimage routes in the dataset",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "routes"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "SemVer schema version"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of generation"
    },
    "routes": {
      "type": "array",
      "items": { "$ref": "#/$defs/RouteEntry" }
    }
  },
  "$defs": {
    "LocalizedString": {
      "type": "object",
      "required": ["en"],
      "properties": {
        "en": { "type": "string" }
      },
      "additionalProperties": { "type": "string" },
      "description": "Localized string keyed by BCP 47 language tag. English required."
    },
    "RouteEntry": {
      "type": "object",
      "required": ["id", "name", "region", "country", "distanceKm", "topology", "tradition", "path"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "description": "Stable kebab-case route identifier"
        },
        "name": { "$ref": "#/$defs/LocalizedString" },
        "region": {
          "type": "string",
          "enum": ["Europe", "Asia", "Americas", "Africa", "Oceania", "Middle East"]
        },
        "country": {
          "type": "string",
          "pattern": "^[A-Z]{2}$",
          "description": "ISO 3166-1 alpha-2 country code"
        },
        "distanceKm": {
          "type": "number",
          "minimum": 0
        },
        "topology": {
          "type": "string",
          "enum": ["linear", "circular", "network"]
        },
        "tradition": {
          "type": "string",
          "enum": ["christian", "buddhist", "shinto", "multi-faith", "secular", "mixed"]
        },
        "path": {
          "type": "string",
          "description": "Relative path from repo root to route directory"
        },
        "variants": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "name", "distanceKm", "path"],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-z0-9-]+$"
              },
              "name": { "$ref": "#/$defs/LocalizedString" },
              "distanceKm": {
                "type": "number",
                "minimum": 0
              },
              "path": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
