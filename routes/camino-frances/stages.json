      "terrainNotes": { "en": "Notable climb to Alto del Perdón (770 m) with iconic pilgrim monument sculpture on the ridge. Rocky descent on the far side." },
      "accommodationDensity": "moderate",
      "waterSources": 4,
      "services": { "atm": true, "pharmacy": true, "grocery": true, "restaurant": true },
      "interior": {
        "theme": { "en": "Forgiveness" },
        "narrative": { "en": "The Alto del Perdón — the Height of Forgiveness. The name is not accidental. The wind turbines hum on the ridge and the pilgrim monument faces west, frozen in eternal walking. Below, the land opens into the wide valleys of Navarra. Something about standing at this high point with the word 'forgiveness' in the air invites pilgrims to consider what they might release." },
        "commonExperiences": [
          { "en": "Awe at the panoramic views from the ridge" },
          { "en": "Photographs at the pilgrim monument" },
          { "en": "Knee pain from the rocky descent" }
        ],
        "reflection": { "en": "What would you forgive if you could? Who would you forgive?" }
      }
    },
