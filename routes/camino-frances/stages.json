      "distanceKm": 21.4,
      "elevationGainMeters": 732,
      "elevationLossMeters": 310,
      "highPointMeters": 945,
      "lowPointMeters": 530,
      "estimatedHours": { "min": 5, "max": 7 },
      "difficulty": "moderate",
      "terrainTypes": ["forest", "dirt", "paved"],
      "accommodationDensity": "moderate",
      "waterSources": 4,
      "services": { "atm": true, "pharmacy": false, "grocery": true, "restaurant": true },
      "interior": {
        "theme": { "en": "Recovery" },
        "narrative": { "en": "After yesterday's trial, today is gentler. The beech forests of Navarra wrap around you. Your body hurts in ways you didn't expect. This is when the Camino teaches its first lesson: you cannot will your way through this. You must negotiate with your body, not command it." },
        "commonExperiences": [
          { "en": "Muscle soreness and blisters emerging" },
          { "en": "Finding your natural pace" },
          { "en": "First real conversations with other pilgrims" }
        ],
        "reflection": { "en": "How do you treat your body when it asks you to slow down?" }
      }
    },
