      "elevationLossMeters": 148,
      "highPointMeters": 900,
      "lowPointMeters": 810,
      "estimatedHours": { "min": 5, "max": 6 },
      "difficulty": "moderate",
      "terrainTypes": ["dirt", "gravel"],
      "terrainNotes": { "en": "The meseta begins. Open plains, cereal fields, dirt and loose stone paths. Little shade." },
      "accommodationDensity": "low",
      "waterSources": 2,
      "services": { "atm": false, "pharmacy": false, "grocery": true, "restaurant": true },
      "interior": {
        "theme": { "en": "Threshold" },
        "narrative": { "en": "You leave Burgos and the landscape changes. The meseta — the vast central plateau of Spain — opens before you. It is flat, dry, and exposed. Many pilgrims dread it. Those who embrace it often name it the most transformative part of the Camino. The meseta does not give you anything to look at. It gives you yourself." },
        "commonExperiences": [
          { "en": "Anxiety about the meseta ahead" },
          { "en": "Leaving the comfort of a major city" },
          { "en": "The landscape suddenly feeling very empty" }
        ],
        "reflection": { "en": "What happens when there is nothing to distract you?" }
      }
    },
    {
      "index": 13,
      "name": { "en": "Hornillos del Camino to Castrojeriz" },
      "start": { "name": { "en": "Hornillos del Camino" }, "coordinates": [-3.912, 42.337, 810] },
      "end": { "name": { "en": "Castrojeriz" }, "coordinates": [-4.140, 42.289, 800] },
      "distanceKm": 19.9,
      "elevationGainMeters": 174,
      "elevationLossMeters": 188,
      "highPointMeters": 900,
      "lowPointMeters": 800,
      "estimatedHours": { "min": 5, "max": 6 },
      "difficulty": "moderate",
      "terrainTypes": ["dirt", "gravel"],
      "accommodationDensity": "low",
      "waterSources": 2,
      "services": { "atm": false, "pharmacy": false, "grocery": true, "restaurant": true },
      "interior": {
        "theme": { "en": "Emptiness" },
        "narrative": { "en": "The meseta is where most pilgrims break open. The landscape offers nothing to look at, nowhere to hide, no distraction. Your mind runs out of things to think about. What remains is what you came here to find. The ruins of San Antón monastery appear like a mirage — a reminder that others have walked this emptiness for centuries." },
        "commonExperiences": [
          { "en": "Boredom giving way to unexpected peace" },
          { "en": "Time distortion — hours pass without awareness" },
          { "en": "First experience of walking meditation without trying" },
          { "en": "Loneliness or profound solitude, sometimes both in the same hour" }
        ],
        "reflection": { "en": "When the landscape offers you nothing, what do you find inside?" }
      }
    },
