      "name": { "en": "Saint-Jean-Pied-de-Port to Roncesvalles", "es": "Saint-Jean-Pied-de-Port a Roncesvalles" },
      "start": { "name": { "en": "Saint-Jean-Pied-de-Port" }, "coordinates": [-1.236, 43.163, 172] },
      "end": { "name": { "en": "Roncesvalles" }, "coordinates": [-1.319, 43.010, 945] },
      "distanceKm": 24.2,
      "elevationGainMeters": 1419,
      "elevationLossMeters": 557,
      "highPointMeters": 1430,
      "lowPointMeters": 172,
      "estimatedHours": { "min": 7, "max": 9 },
      "difficulty": "hard",
      "terrainTypes": ["mountain", "gravel", "forest"],
      "terrainNotes": { "en": "Two route options: the Napoleon Route over the pass (harder, more scenic, closed Nov-Mar) and the Valcarlos Route through the valley (longer at 28 km but lower elevation)." },
      "accommodationDensity": "low",
      "waterSources": 3,
      "services": { "atm": true, "pharmacy": true, "grocery": true, "restaurant": true },
      "warnings": [
        { "en": "The Napoleon Route closes in severe weather (typically Nov 1 - Mar 31). Check conditions at the SJPP pilgrim office before departing." },
        { "en": "This is the hardest day and it is the first day. Many pilgrims underestimate the Pyrenees crossing." }
      ],
      "interior": {
        "theme": { "en": "Initiation" },
        "narrative": { "en": "The Pyrenees crossing is the hardest day and it is the first day. This is not an accident. The route breaks you open before you have built up defenses. The climb strips away everything you thought you needed — the extra weight in your pack, the pace you imagined you'd keep, the version of yourself you planned to be. Many pilgrims arrive in Roncesvalles having cried for reasons they cannot articulate." },
        "commonExperiences": [
          { "en": "Physical shock at the difficulty" },
          { "en": "Doubt about whether to continue" },
          { "en": "Unexpected emotional release during the descent" },
          { "en": "First encounter with the albergue communal experience" },
          { "en": "Gratitude for the pilgrim blessing at Roncesvalles chapel" }
        ],
        "reflection": { "en": "What did you carry up that mountain that you did not need?" }
      }
    },
    {
      "index": 1,
      "name": { "en": "Roncesvalles to Zubiri" },
      "start": { "name": { "en": "Roncesvalles" }, "coordinates": [-1.319, 43.010, 945] },
