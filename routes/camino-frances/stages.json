    {
      "index": 12,
      "name": { "en": "Burgos to Hornillos del Camino" },
      "start": { "name": { "en": "Burgos" }, "coordinates": [-3.700, 42.344, 860] },
      "end": { "name": { "en": "Hornillos del Camino" }, "coordinates": [-3.912, 42.337, 810] },
